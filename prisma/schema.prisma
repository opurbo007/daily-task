generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  telegramChatId String?
  streakCount    Int       @default(0)
  lastActiveDate DateTime?
  theme          String    @default("dark")
  notificationSettings Json @default("{\"browser\": true, \"telegram\": true, \"dailyReminder\": true, \"overdueAlert\": true}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  tasks         Task[]
  weeklyReports WeeklyReport[]
  notifications Notification[]
  tags          Tag[]
  spaceCards    SpaceCard[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Task {
  id            String     @id @default(cuid())
  title         String
  description   String?    @db.Text
  dueDate       DateTime?
  priority      Priority   @default(MEDIUM)
  status        TaskStatus @default(PENDING)
  estimatedTime Int?
  actualTime    Int?
  sortOrder     Int        @default(0)
  completedAt   DateTime?
  reminderSent  Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tags TaskTag[]

  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([userId, priority])
  @@map("tasks")
}

model Tag {
  id    String @id @default(cuid())
  name  String
  color String @default("#6366f1")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks TaskTag[]

  @@unique([userId, name])
  @@map("tags")
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@map("task_tags")
}

model WeeklyReport {
  id               String   @id @default(cuid())
  weekStart        DateTime
  weekEnd          DateTime
  totalCreated     Int      @default(0)
  totalCompleted   Int      @default(0)
  completionRate   Float    @default(0)
  mostProductiveDay String?
  overdueCount     Int      @default(0)
  dailyBreakdown   Json     @default("[]")
  sentToTelegram   Boolean  @default(false)
  createdAt        DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("weekly_reports")
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

enum SpaceCardType {
  BOOKMARK
  NOTE
  CODE
  OTHER
}

model SpaceCard {
  id        String        @id @default(cuid())
  title     String
  type      SpaceCardType @default(NOTE)
  content   String?       @db.Text
  url       String?
  color     String        @default("#6366f1")
  pinned    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("space_cards")
}
